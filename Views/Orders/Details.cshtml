@model UPTEST.Models.Order

@{
    ViewData["Title"] = "Детали заказа";
}

<h1>Детали заказа</h1>

<div>
    <h4>@Model.OrderNumber</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CustomerName)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.CustomerName)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CustomerPhone)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.CustomerPhone)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Category)</dt>
        <dd class="col-sm-9">@(Model.Category?.CategoryName ?? "—")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ItemDescription)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ItemDescription)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.StainType)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.StainType)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Quantity)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Quantity)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Status)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Priority)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Priority)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.TotalPrice)</dt>
        <dd class="col-sm-9">@Model.TotalPrice.ToString("N2") ₽</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DiscountAmount)</dt>
        <dd class="col-sm-9">@Model.DiscountAmount.ToString("N2") ₽</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FinalPrice)</dt>
        <dd class="col-sm-9">@Model.FinalPrice.ToString("N2") ₽</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PaymentStatus)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.PaymentStatus)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PaymentMethod)</dt>
        <dd class="col-sm-9">@(Model.PaymentMethod ?? "—")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
        <dd class="col-sm-9">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PickupDate)</dt>
        <dd class="col-sm-9">@(Model.PickupDate?.ToString("dd.MM.yyyy HH:mm") ?? "—")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CompletedAt)</dt>
        <dd class="col-sm-9">@(Model.CompletedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.User)</dt>
        <dd class="col-sm-9">@(Model.User?.FullName ?? "—")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Customer)</dt>
        <dd class="col-sm-9">@(Model.Customer?.FullName ?? "Разовый клиент")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ModifiedBy)</dt>
        <dd class="col-sm-9">@(Model.ModifiedBy?.FullName ?? "—")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.LastModifiedAt)</dt>
        <dd class="col-sm-9">@(Model.LastModifiedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Notes)</dt>
        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Notes) ? "—" : Model.Notes)</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.OrderId">Изменить</a> |
    <a asp-action="Index">Назад к списку</a>
</div>
