@model IEnumerable<UPTEST.Models.Order>

@{
    ViewData["Title"] = "Заказы";
}

<h1>Заказы</h1>
<p class="text-muted">Контроль статусов, сумм и ответственных по каждому заказу.</p>

<p>
    <a asp-action="Create" class="btn btn-primary">Создать заказ</a>
</p>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.OrderNumber)</th>
                <th>@Html.DisplayNameFor(model => model.CustomerName)</th>
                <th>@Html.DisplayNameFor(model => model.CustomerPhone)</th>
                <th>@Html.DisplayNameFor(model => model.Status)</th>
                <th>@Html.DisplayNameFor(model => model.Priority)</th>
                <th>@Html.DisplayNameFor(model => model.FinalPrice)</th>
                <th>@Html.DisplayNameFor(model => model.PaymentStatus)</th>
                <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
                <th>Ответственные</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <strong>@Html.DisplayFor(modelItem => item.OrderNumber)</strong><br />
                    <span class="text-muted small">@(item.Category?.CategoryName ?? "—")</span>
                </td>
                <td>@Html.DisplayFor(modelItem => item.CustomerName)</td>
                <td>@Html.DisplayFor(modelItem => item.CustomerPhone)</td>
                <td>@Html.DisplayFor(modelItem => item.Status)</td>
                <td>@Html.DisplayFor(modelItem => item.Priority)</td>
                <td>@item.FinalPrice.ToString("N2") ₽</td>
                <td>@Html.DisplayFor(modelItem => item.PaymentStatus)</td>
                <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <div>Менеджер: @(item.User?.FullName ?? "—")</div>
                    <div class="text-muted small">Изменил: @(item.ModifiedBy?.FullName ?? "—")</div>
                </td>
                <td class="text-nowrap">
                    <a asp-action="Edit" asp-route-id="@item.OrderId">Изменить</a> |
                    <a asp-action="Details" asp-route-id="@item.OrderId">Детали</a> |
                    <a asp-action="Delete" asp-route-id="@item.OrderId">Удалить</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
