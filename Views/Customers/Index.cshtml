@model IEnumerable<UPTEST.Models.Customer>

@{
    ViewData["Title"] = "Клиенты";
}

<section class="entity-page">
    <div class="entity-page__header">
        <div>
            <p class="entity-page__eyebrow">CRM</p>
            <h1>Клиенты</h1>
            <p class="entity-page__description">Управляйте клиентской базой, контактами и историей обращений в одном месте.</p>
        </div>
        <a class="btn btn-dark entity-page__cta" asp-action="Create">СОЗДАТЬ КЛИЕНТА</a>
    </div>

    <div class="table-responsive entity-table-wrap">
        <table class="table entity-table align-middle">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.FullName)</th>
                    <th>@Html.DisplayNameFor(model => model.PhoneNumber)</th>
                    <th>@Html.DisplayNameFor(model => model.Email)</th>
                    <th>@Html.DisplayNameFor(model => model.Address)</th>
                    <th>@Html.DisplayNameFor(model => model.DiscountCard)</th>
                    <th>@Html.DisplayNameFor(model => model.DiscountPercent)</th>
                    <th>@Html.DisplayNameFor(model => model.TotalOrders)</th>
                    <th>@Html.DisplayNameFor(model => model.TotalSpent)</th>
                    <th>@Html.DisplayNameFor(model => model.RegistrationDate)</th>
                    <th>@Html.DisplayNameFor(model => model.Notes)</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.FullName)</td>
                    <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                    <td>@Html.DisplayFor(modelItem => item.Email)</td>
                    <td>@Html.DisplayFor(modelItem => item.Address)</td>
                    <td>@Html.DisplayFor(modelItem => item.DiscountCard)</td>
                    <td>@Html.DisplayFor(modelItem => item.DiscountPercent)</td>
                    <td>@Html.DisplayFor(modelItem => item.TotalOrders)</td>
                    <td>@Html.DisplayFor(modelItem => item.TotalSpent)</td>
                    <td>@Html.DisplayFor(modelItem => item.RegistrationDate)</td>
                    <td>@Html.DisplayFor(modelItem => item.Notes)</td>
                    <td class="text-end">
                        <div class="entity-table__actions">
                            <a asp-action="Edit" asp-route-id="@item.CustomerId">Изменить</a>
                            <a asp-action="Details" asp-route-id="@item.CustomerId">Подробнее</a>
                            <a asp-action="Delete" asp-route-id="@item.CustomerId">Удалить</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
