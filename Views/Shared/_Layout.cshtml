@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString()?.ToLowerInvariant();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString()?.ToLowerInvariant();
    var isHomePage = currentController == "home" && currentAction == "index";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UPTEST</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UPTEST.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg site-navbar">
            <div class="container site-navbar-container">
                <a class="navbar-brand site-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span>UP</span>TEXTILE
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Переключить навигацию">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Главная</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Index#services">Услуги</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Index#workspace-tabs">Вкладки</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Index#contact">Контакты</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">О проекте</a></li>

                        @if (isAuthenticated)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Orders" asp-action="Index">Заказы</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Customers" asp-action="Index">Клиенты</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Services" asp-action="Index">Сервисы</a></li>
                            <li class="nav-item ms-lg-3">
                                <div class="user-badge">
                                    <span>@User.Identity?.Name</span>
                                    <small>@(string.IsNullOrWhiteSpace(userRole) ? "Сотрудник" : userRole)</small>
                                </div>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-dark nav-auth-btn">Выйти</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-2"><a class="btn btn-dark nav-cta" asp-controller="Account" asp-action="Auth">Вход / регистрация</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (isHomePage)
    {
        <main role="main" class="page-main home-main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container page-main inner-page-main">
            <main role="main" class="pb-4">
                @RenderBody()
            </main>
        </div>
    }

    <footer class="site-footer">
        <div class="container site-footer-container">
            <div>
                <strong>UPTEXTILE</strong>
                <p class="mb-0">Промо-сайт и рабочий кабинет прачечного сервиса с авторизацией для сотрудников.</p>
            </div>
            <div class="site-footer-links">
                <a asp-area="" asp-controller="Home" asp-action="Index">Главная</a>
                <a asp-area="" asp-controller="Account" asp-action="Auth">Кабинет</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
